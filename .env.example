RECEIVER_URL=http://receiver-pi.local:8787/ingest/now-playing
SOURCE_NAME=raspotify-pi
LOG_LEVEL=info
SPOTIFY_CLIENT_ID=replace-me
SPOTIFY_CLIENT_SECRET=replace-me
POLL_INTERVAL=2s
HTTP_TIMEOUT=10s
INITIAL_RETRY_DELAY=2s
MAX_RETRY_DELAY=1m
HOST_RUNTIME_DIR=./runtime
SPOOL_FILE=runtime/spool/current_event.json
STATE_FILE=runtime/state/sender_state.json
TRACK_EVENTS=start,started,playing,changed,track_changed,loading
STOP_EVENTS=stopped,stop,session_disconnected
